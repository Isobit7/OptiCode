# Supabase Configuration (Server-Side Only - Service Key)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# Google OAuth & Cloud Configuration
GOOGLE_PROJECT_ID=spherical-proxy-465806-c4
GOOGLE_CLIENT_ID=658164413244-your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Groq API Configuration (Ultra-Fast <500ms inference)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODELS=llama-3.3-70b-versatile,deepseek-r1-distill-llama-70b,llama3-8b-8192

# Google Gemini API Configuration (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODELS=gemini-2.5-flash,gemini-1.5-flash

# LLM API Configuration (Configured for OpenRouter / OpenAI-compatible endpoints)
LLM_API_KEY=your-llm-api-key-here
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free,deepseek/deepseek-r1:free,qwen/qwen-2.5-coder-32b-instruct:free,google/gemma-2-9b-it:free,mistralai/mistral-7b-instruct:free,poolside/laguna-s-2.1:free

# Application Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,*
RATE_LIMIT_PER_MINUTE=10
